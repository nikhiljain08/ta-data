# TallySync — environment variable template
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL DSN including credentials.
# Supabase example:
#   postgresql+psycopg://postgres:<password>@db.<project>.supabase.co:5432/postgres
# Local PostgreSQL example:
#   postgresql+psycopg://tallysync:<password>@localhost:5432/tallysync
TALLYSYNC_DATABASE__URL=postgresql+psycopg://user:password@host:5432/dbname

# ── Tally ─────────────────────────────────────────────────────────────────────
# TALLYSYNC_TALLY__HOST=localhost
# TALLYSYNC_TALLY__PORT=9000
# TALLYSYNC_TALLY__COMPANY_NAME=My Company Ltd

# ── Security ──────────────────────────────────────────────────────────────────
# Set to false if not using Windows Credential Manager
# TALLYSYNC_SECURITY__USE_KEYRING=false

# ── Logging ───────────────────────────────────────────────────────────────────
# TALLYSYNC_LOGGING__LEVEL=DEBUG
