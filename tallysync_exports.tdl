;; =========================================================================
;; LEDGER MASTERS
;; =========================================================================

[Report : TS_LED_REPORT]
    Form : TS_LED_FORM

[Form : TS_LED_FORM]
    Parts   : TS_LED_PART
    XML Tag : "TS_LED_LIST"

[Part : TS_LED_PART]
    Lines    : TS_LED_LINE
    Repeat   : TS_LED_LINE : TS_LED_COLL
    Scrolled : Vertical

[Line : TS_LED_LINE]
    Fields  : TS_LED_F0, TS_LED_F1, TS_LED_F2, TS_LED_F3, TS_LED_F4, TS_LED_F5, TS_LED_F6, TS_LED_F7, TS_LED_F8, TS_LED_F9, TS_LED_F10, TS_LED_F11, TS_LED_F12, TS_LED_F13, TS_LED_F14
    Explode : TS_LED_SP0
    Explode : TS_LED_SP1
    XML Tag : "LEDGER"

[Field : TS_LED_F0]
    Set as  : $Name
    XML Tag : "NAME"

[Field : TS_LED_F1]
    Set as  : $GUID
    XML Tag : "GUID"

[Field : TS_LED_F2]
    Set as  : $Parent
    XML Tag : "PARENT"

[Field : TS_LED_F3]
    Set as  : $$YesNo:$IsDeemedPositive
    XML Tag : "ISDEEMEDPOSITIVE"

[Field : TS_LED_F4]
    Set as  : $OpeningBalance
    XML Tag : "OPENINGBALANCE"

[Field : TS_LED_F5]
    Set as  : $ClosingBalance
    XML Tag : "CLOSINGBALANCE"

[Field : TS_LED_F6]
    Set as  : $GSTRegistrationType
    XML Tag : "GSTREGISTRATIONTYPE"

[Field : TS_LED_F7]
    Set as  : $GSTIN
    XML Tag : "GSTIN"

[Field : TS_LED_F8]
    Set as  : $IncomeTaxNumber
    XML Tag : "INCOMETAXNUMBER"

[Field : TS_LED_F9]
    Set as  : $LedgerMobile
    XML Tag : "LEDGERMOBILE"

[Field : TS_LED_F10]
    Set as  : $LedgerEmail
    XML Tag : "LEDGEREMAIL"

[Field : TS_LED_F11]
    Set as  : $CountryName
    XML Tag : "COUNTRYNAME"

[Field : TS_LED_F12]
    Set as  : $LedgerStateName
    XML Tag : "LEDGERSTATENAME"

[Field : TS_LED_F13]
    Set as  : $PINCode
    XML Tag : "PINCODE"

[Field : TS_LED_F14]
    Set as  : $AlterID
    XML Tag : "ALTERID"

[Collection : TS_LED_COLL]
    Type   : Ledger

;; $GSTIN returns nothing as a flat field on Ledger; TallyPrime 7 stores GST
;; registration details in the LedGSTRegDetails sub-collection.  One entry per
;; registration period — typically one per ledger.
[Part : TS_LED_SP0]
    Lines  : TS_LED_SP0_LINE
    Repeat : TS_LED_SP0_LINE : LedGSTRegDetails

[Line : TS_LED_SP0_LINE]
    Fields  : TS_LED_SP0_F0
    XML Tag : "LEDGSTREGDETAILS.LIST"

[Field : TS_LED_SP0_F0]
    Set as  : $GSTIN
    XML Tag : "GSTIN"

;; $LedgerEmail and flat ADDRESS.LIST return nothing; email and address live in
;; the LedMailingDetails sub-collection (one entry per mailing address on the ledger).
[Part : TS_LED_SP1]
    Lines  : TS_LED_SP1_LINE
    Repeat : TS_LED_SP1_LINE : LedMailingDetails

[Line : TS_LED_SP1_LINE]
    Fields  : TS_LED_SP1_F0, TS_LED_SP1_F1
    XML Tag : "LEDMAILINGDETAILS.LIST"

[Field : TS_LED_SP1_F0]
    Set as  : $Email
    XML Tag : "EMAIL"

[Field : TS_LED_SP1_F1]
    Set as  : $Address
    XML Tag : "ADDRESS"

