;; =========================================================================
;; TallySync — Custom Export Reports
;; Version: 1.0
;;
;; ONE-TIME SETUP
;; --------------
;; 1. Note the full path to this file (e.g. C:\TallySync\tallysync_exports.tdl)
;; 2. Open TallyPrime
;; 3. Gateway of Tally → press F12 (Configure)
;;    OR Alt+F3 → F12 (Company Features) → Accept with defaults
;;    → TDL & Add-on Files → specify path to this file
;; 4. Restart TallyPrime  (or press Ctrl+Alt+R to hot-reload if available)
;;
;; After loading, the reports TS_CMP_REPORT, TS_GRP_REPORT, TS_LED_REPORT,
;; TS_UNIT_REPORT, TS_SGRP_REPORT, TS_GDN_REPORT, TS_VTYP_REPORT,
;; TS_SITM_REPORT, and TS_VOC_REPORT become available for HTTP export.
;;
;; INCREMENTAL SYNC
;; ----------------
;; The variable TSALTERID is set by the HTTP request (STATICVARIABLES).
;;   TSALTERID = -1  → full sync: all records returned
;;   TSALTERID = N   → incremental sync: only records with AlterID > N
;; =========================================================================

;; Incremental sync note
;; ---------------------
;; AlterID-based incremental filtering is performed in the agent (Python)
;; after parsing, NOT in TDL.  Custom variables passed via HTTP
;; STATICVARIABLES are not reliably accessible inside collection filters,
;; so every collection returns its full set and the agent drops records
;; with AlterID <= the stored checkpoint.  Voucher exports are still bounded
;; server-side by the SVFROMDATE/SVTODATE period filter.

;; =========================================================================
;; REAL-TIME EVENT TRIGGERS
;; =========================================================================
;; [System : Events] registers callbacks for TallyPrime object save/delete.
;; Each entity has its own Function (System Events do not support parameters).
;; $$HTTPGET fires a GET to the TallySync agent which enqueues an incremental
;; sync for that entity.  If the agent is not running the call silently fails.
;; =========================================================================

;; ── Per-entity HTTP trigger functions ────────────────────────────────────

[Function : TSSyncVoucher]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/voucher"

[Function : TSSyncLedger]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/ledger"

[Function : TSSyncStockItem]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/stock_item"

[Function : TSSyncLedgerGroup]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/ledger_group"

[Function : TSSyncStockGroup]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/stock_group"

[Function : TSSyncGodown]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/godown"

[Function : TSSyncVoucherType]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/voucher_type"

[Function : TSSyncUnit]
    Variable : lR : String
    10 : SET : lR : $$HTTPGET:"http://127.0.0.1:8765/sync/entity/unit"

;; ── Event registrations ───────────────────────────────────────────────────

[System : Events]
    Event : Save Voucher      : TSSyncVoucher
    Event : Delete Voucher    : TSSyncVoucher
    Event : Save Ledger       : TSSyncLedger
    Event : Delete Ledger     : TSSyncLedger
    Event : Save StockItem    : TSSyncStockItem
    Event : Delete StockItem  : TSSyncStockItem
    Event : Save Group        : TSSyncLedgerGroup
    Event : Delete Group      : TSSyncLedgerGroup
    Event : Save StockGroup   : TSSyncStockGroup
    Event : Delete StockGroup : TSSyncStockGroup
    Event : Save Godown       : TSSyncGodown
    Event : Delete Godown     : TSSyncGodown
    Event : Save VoucherType  : TSSyncVoucherType
    Event : Delete VoucherType: TSSyncVoucherType
    Event : Save Unit         : TSSyncUnit
    Event : Delete Unit       : TSSyncUnit

;; =========================================================================
;; PURCHASE ORDERS
;; Type: Voucher filtered to "Purchase Order" voucher type.
;; Stores intended purchases before a Purchase Bill is created.
;; =========================================================================

[Report : TS_PO_REPORT]
    Form : TS_PO_FORM

[Form : TS_PO_FORM]
    Parts   : TS_PO_PART
    XML Tag : "TS_PO_LIST"

[Part : TS_PO_PART]
    Lines    : TS_PO_LINE
    Repeat   : TS_PO_LINE : TS_PO_COLL
    Scrolled : Vertical

[Line : TS_PO_LINE]
    Fields  : TS_PO_F0, TS_PO_F1, TS_PO_F2, TS_PO_F3, TS_PO_F4, TS_PO_F5, TS_PO_F6, TS_PO_F7, TS_PO_F8
    Explode : TS_PO_ITEMS
    XML Tag : "VOUCHER"

[Field : TS_PO_F0]
    Set as  : $VoucherNumber
    XML Tag : "VOUCHERNUMBER"

[Field : TS_PO_F1]
    Set as  : $Date
    XML Tag : "DATE"

[Field : TS_PO_F2]
    Set as  : $PartyLedgerName
    XML Tag : "PARTYLEDGERNAME"

[Field : TS_PO_F3]
    Set as  : $Narration
    XML Tag : "NARRATION"

[Field : TS_PO_F4]
    Set as  : $OrderDueDate
    XML Tag : "ORDERDUEDATE"

[Field : TS_PO_F5]
    Set as  : $$YesNo:$IsCancelled
    XML Tag : "ISCANCELLED"

[Field : TS_PO_F6]
    Set as  : $$YesNo:$IsOptional
    XML Tag : "ISOPTIONAL"

[Field : TS_PO_F7]
    Set as  : $GUID
    XML Tag : "GUID"

[Field : TS_PO_F8]
    Set as  : $AlterID
    XML Tag : "ALTERID"

[Collection : TS_PO_COLL]
    Type   : Voucher
    Fetch  : VoucherNumber, Date, PartyLedgerName, Narration, OrderDueDate, IsCancelled, IsOptional, GUID, AlterID, AllInventoryEntries.*
    Filter : TS_IsPO

[System : Formula]
    TS_IsPO : $VoucherTypeName = "Purchase Order"

;; ── Purchase Order inventory items sub-part ──────────────────────────────

[Part : TS_PO_ITEMS]
    Lines  : TS_PO_ITEM_LINE
    Repeat : TS_PO_ITEM_LINE : AllinventoryEntries

[Line : TS_PO_ITEM_LINE]
    Fields  : TS_PO_IT_F0, TS_PO_IT_F1, TS_PO_IT_F2, TS_PO_IT_F3, TS_PO_IT_F4, TS_PO_IT_F5
    XML Tag : "ALLINVENTORYENTRIES.LIST"

[Field : TS_PO_IT_F0]
    Set as  : $StockItemName
    XML Tag : "STOCKITEMNAME"

[Field : TS_PO_IT_F1]
    Set as  : $ActualQty
    XML Tag : "ACTUALQTY"

[Field : TS_PO_IT_F2]
    Set as  : $BilledQty
    XML Tag : "BILLEDQTY"

[Field : TS_PO_IT_F3]
    Set as  : $Rate
    XML Tag : "RATE"

[Field : TS_PO_IT_F4]
    Set as  : $Amount
    XML Tag : "AMOUNT"

[Field : TS_PO_IT_F5]
    Set as  : $GodownName
    XML Tag : "GODOWNNAME"

;; =========================================================================
;; COMPANY
;; Type: Company (gateway-scoped — do not set SVCURRENTCOMPANY)
;; =========================================================================

[Report : TS_CMP_REPORT]
    Form : TS_CMP_FORM

[Form : TS_CMP_FORM]
    Parts   : TS_CMP_PART
    XML Tag : "TS_CMP_LIST"

[Part : TS_CMP_PART]
    Lines    : TS_CMP_LINE
    Repeat   : TS_CMP_LINE : TS_CMP_COLL
    Scrolled : Vertical

[Line : TS_CMP_LINE]
    Fields  : TS_CMP_F0, TS_CMP_F1, TS_CMP_F2, TS_CMP_F3, TS_CMP_F4, TS_CMP_F5, TS_CMP_F6, TS_CMP_F7, TS_CMP_F8
    Explode : TS_CMP_SP0
    XML Tag : "COMPANY"

[Field : TS_CMP_F0]
    Set as  : $Name
    XML Tag : "NAME"

[Field : TS_CMP_F1]
    Set as  : $GUID
    XML Tag : "GUID"

[Field : TS_CMP_F2]
    Set as  : $BooksFrom
    XML Tag : "BOOKSBEGINNINGFROM"

[Field : TS_CMP_F3]
    Set as  : $StartingFrom
    XML Tag : "STARTINGFROM"

[Field : TS_CMP_F4]
    Set as  : $EndingAt
    XML Tag : "ENDINGAT"

[Field : TS_CMP_F5]
    Set as  : $CountryName
    XML Tag : "COUNTRYNAME"

[Field : TS_CMP_F6]
    Set as  : $StateName
    XML Tag : "STATENAME"

[Field : TS_CMP_F7]
    Set as  : $GSTIN
    XML Tag : "GSTIN"

[Field : TS_CMP_F8]
    Set as  : $AlterID
    XML Tag : "ALTERID"

;; Company collection is gateway-level — no filter needed
[Collection : TS_CMP_COLL]
    Type : Company

;; Flat $GSTIN on Company returns nothing; the value (when entered) lives in
;; the GSTDetails sub-collection — confirmed by probe P_C2.
[Part : TS_CMP_SP0]
    Lines  : TS_CMP_SP0_LINE
    Repeat : TS_CMP_SP0_LINE : GSTDetails

[Line : TS_CMP_SP0_LINE]
    Fields  : TS_CMP_SP0_F0
    XML Tag : "GSTDETAILS.LIST"

[Field : TS_CMP_SP0_F0]
    Set as  : $GSTIN
    XML Tag : "GSTIN"

